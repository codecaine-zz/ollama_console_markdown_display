# VHS Tape File - Ollama Console Markdown Display Demo
# Run: vhs demo.tape

# Settings
Output demo.gif
Set FontSize 16
Set Width 1200
Set Height 600
Set Theme "Catppuccin Mocha"
Set TypingSpeed 50ms
Set Shell "zsh"

# Start the demo
Sleep 500ms

# Show one-liner mode
Type "bun run index.ts 'write a hello world function in python'"
Sleep 500ms
Enter
Sleep 25s

# Pause to let the user see the output
Sleep 3s
